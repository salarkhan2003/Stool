{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stool App Schema",
  "description": "Personal Outreach & Thought Tracker Data Structure",
  "type": "object",
  "properties": {
    "thoughts": {
      "type": "array",
      "items": {
        "type": "object",
        "title": "Ephemeral Thought",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "was_i_right": { "type": ["boolean", "null"] }
        },
        "required": ["id", "content", "timestamp"]
      }
    },
    "lists": {
      "type": "array",
      "items": {
        "type": "object",
        "title": "Outreach List",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "items": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "object",
              "title": "Outreach Item",
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "phone_number": { "type": "string" },
                "email": { "type": "string" },
                "current_status": {
                  "type": "string",
                  "enum": ["To Research", "Contacted", "Feedback Given", "Finished"]
                },
                "feedback_log": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "sub_tasks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "text": { "type": "string" },
                      "completed": { "type": "boolean" }
                    },
                    "required": ["id", "text", "completed"]
                  }
                }
              },
              "required": ["id", "title", "current_status", "feedback_log", "sub_tasks"]
            }
          }
        },
        "required": ["id", "name", "items"]
      }
    }
  }
}
